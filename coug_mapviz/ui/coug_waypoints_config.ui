<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">

  <!--
  @file coug_waypoints_config.ui
  @brief UI for the CougWaypointsPlugin.
  @author Nelson Durrant
  @date Jan 2026
  -->

  <class>coug_waypoints_config</class>
  <widget class="QWidget" name="coug_waypoints_config">
    <property name="geometry">
      <rect><x>0</x><y>0</y><width>404</width><height>560</height></rect>
    </property>
    <property name="windowTitle"><string>Form</string></property>
    <property name="styleSheet"><string notr="true" /></property>

    <layout class="QGridLayout" name="gridLayout">
      <property name="leftMargin"><number>2</number></property>
      <property name="topMargin"><number>2</number></property>
      <property name="rightMargin"><number>2</number></property>
      <property name="bottomMargin"><number>2</number></property>
      <property name="verticalSpacing"><number>6</number></property>

      <!-- ═══ Row 0: Topic ═══ -->
      <item row="0" column="0">
        <widget class="QLabel" name="label_topic">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Waypoints Topic:</string></property>
        </widget>
      </item>
      <item row="0" column="1" colspan="3">
        <widget class="QComboBox" name="topic_selector">
          <property name="editable"><bool>false</bool></property>
        </widget>
      </item>

      <!-- ═══ Row 1: Mission Defaults header ═══ -->
      <item row="1" column="0" colspan="4">
        <widget class="QLabel" name="label_mission_defaults">
          <property name="font">
            <font><family>Sans Serif</family><pointsize>8</pointsize><bold>true</bold></font>
          </property>
          <property name="text"><string>Mission Defaults</string></property>
          <property name="styleSheet">
            <string notr="true">QLabel { border-bottom: 1px solid gray; padding-bottom: 2px; }</string>
          </property>
        </widget>
      </item>

      <!-- Row 2: Default Speed -->
      <item row="2" column="0">
        <widget class="QLabel" name="label_default_speed">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Speed:</string></property>
        </widget>
      </item>
      <item row="2" column="1" colspan="3">
        <widget class="QDoubleSpinBox" name="default_speed_editor">
          <property name="decimals"><number>1</number></property>
          <property name="minimum"><double>0.0</double></property>
          <property name="maximum"><double>100.0</double></property>
          <property name="value"><double>50.0</double></property>
          <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
        </widget>
      </item>

      <!-- Row 3: Default Slip Radius -->
      <item row="3" column="0">
        <widget class="QLabel" name="label_default_slip">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Slip Radius:</string></property>
        </widget>
      </item>
      <item row="3" column="1" colspan="3">
        <widget class="QDoubleSpinBox" name="default_slip_radius_editor">
          <property name="decimals"><number>2</number></property>
          <property name="minimum"><double>0.0</double></property>
          <property name="maximum"><double>9999.99</double></property>
          <property name="value"><double>2.0</double></property>
          <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
        </widget>
      </item>

      <!-- Row 4: Default Capture Radius -->
      <item row="4" column="0">
        <widget class="QLabel" name="label_default_capture">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Capture Radius:</string></property>
        </widget>
      </item>
      <item row="4" column="1" colspan="3">
        <widget class="QDoubleSpinBox" name="default_capture_radius_editor">
          <property name="decimals"><number>2</number></property>
          <property name="minimum"><double>0.0</double></property>
          <property name="maximum"><double>9999.99</double></property>
          <property name="value"><double>10.0</double></property>
          <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
        </widget>
      </item>

      <!-- ═══ Row 5: Waypoint Properties header ═══ -->
      <item row="5" column="0" colspan="4">
        <widget class="QLabel" name="label_wp_props">
          <property name="font">
            <font><family>Sans Serif</family><pointsize>8</pointsize><bold>true</bold></font>
          </property>
          <property name="text"><string>Waypoint Properties</string></property>
          <property name="styleSheet">
            <string notr="true">QLabel { border-bottom: 1px solid gray; padding-bottom: 2px; }</string>
          </property>
        </widget>
      </item>

      <!-- Row 6: Depth value -->
      <item row="6" column="0">
        <widget class="QLabel" name="label_depth">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Depth:</string></property>
        </widget>
      </item>
      <item row="6" column="1" colspan="3">
        <widget class="QDoubleSpinBox" name="depth_editor">
          <property name="enabled"><bool>false</bool></property>
          <property name="decimals"><number>2</number></property>
          <property name="minimum"><double>-9999.99</double></property>
          <property name="maximum"><double>9999.99</double></property>
          <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
        </widget>
      </item>

      <!-- Row 7: Depth reference (required) -->
      <item row="7" column="0">
        <widget class="QLabel" name="label_depth_ref">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Depth Ref:</string></property>
        </widget>
      </item>
      <item row="7" column="1" colspan="3">
        <widget class="QComboBox" name="depth_ref_selector">
          <property name="enabled"><bool>false</bool></property>
          <item><property name="text"><string>surface</string></property></item>
          <item><property name="text"><string>bottom</string></property></item>
        </widget>
      </item>

      <!-- Row 8: Park (required) -->
      <item row="8" column="0">
        <widget class="QLabel" name="label_park">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Park:</string></property>
        </widget>
      </item>
      <item row="8" column="1" colspan="3">
        <widget class="QCheckBox" name="park_checkbox">
          <property name="enabled"><bool>false</bool></property>
          <property name="text"><string></string></property>
        </widget>
      </item>

      <!-- Row 9: Speed (optional per-waypoint override) -->
      <item row="9" column="0">
        <widget class="QLabel" name="label_speed">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Speed (opt):</string></property>
        </widget>
      </item>
      <item row="9" column="1" colspan="3">
        <layout class="QHBoxLayout" name="layout_speed">
          <item>
            <widget class="QCheckBox" name="speed_override_checkbox">
              <property name="enabled"><bool>false</bool></property>
              <property name="text"><string>Override</string></property>
            </widget>
          </item>
          <item>
            <widget class="QDoubleSpinBox" name="speed_editor">
              <property name="enabled"><bool>false</bool></property>
              <property name="decimals"><number>1</number></property>
              <property name="minimum"><double>0.0</double></property>
              <property name="maximum"><double>100.0</double></property>
              <property name="value"><double>50.0</double></property>
              <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
            </widget>
          </item>
        </layout>
      </item>

      <!-- Row 10: Slip Radius (optional per-waypoint override) -->
      <item row="10" column="0">
        <widget class="QLabel" name="label_slip_radius">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Slip Radius (opt):</string></property>
        </widget>
      </item>
      <item row="10" column="1" colspan="3">
        <layout class="QHBoxLayout" name="layout_slip_radius">
          <item>
            <widget class="QCheckBox" name="slip_radius_override_checkbox">
              <property name="enabled"><bool>false</bool></property>
              <property name="text"><string>Override</string></property>
            </widget>
          </item>
          <item>
            <widget class="QDoubleSpinBox" name="slip_radius_editor">
              <property name="enabled"><bool>false</bool></property>
              <property name="decimals"><number>2</number></property>
              <property name="minimum"><double>0.0</double></property>
              <property name="maximum"><double>9999.99</double></property>
              <property name="value"><double>2.0</double></property>
              <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
            </widget>
          </item>
        </layout>
      </item>

      <!-- Row 11: Capture Radius (optional per-waypoint override) -->
      <item row="11" column="0">
        <widget class="QLabel" name="label_capture_radius">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Capture Radius (opt):</string></property>
        </widget>
      </item>
      <item row="11" column="1" colspan="3">
        <layout class="QHBoxLayout" name="layout_capture_radius">
          <item>
            <widget class="QCheckBox" name="capture_radius_override_checkbox">
              <property name="enabled"><bool>false</bool></property>
              <property name="text"><string>Override</string></property>
            </widget>
          </item>
          <item>
            <widget class="QDoubleSpinBox" name="capture_radius_editor">
              <property name="enabled"><bool>false</bool></property>
              <property name="decimals"><number>2</number></property>
              <property name="minimum"><double>0.0</double></property>
              <property name="maximum"><double>9999.99</double></property>
              <property name="value"><double>10.0</double></property>
              <property name="buttonSymbols"><enum>QAbstractSpinBox::PlusMinus</enum></property>
            </widget>
          </item>
        </layout>
      </item>

      <!-- ═══ Row 12: Publish / Stop ═══ -->
      <item row="12" column="1" colspan="3">
        <layout class="QHBoxLayout" name="horizontalLayout_pub_stop">
          <item>
            <widget class="QPushButton" name="publish">
              <property name="text"><string>Publish</string></property>
            </widget>
          </item>
          <item>
            <widget class="QPushButton" name="stop">
              <property name="text"><string>Stop</string></property>
            </widget>
          </item>
        </layout>
      </item>

      <!-- Row 13: Save / Load -->
      <item row="13" column="1" colspan="3">
        <layout class="QHBoxLayout" name="horizontalLayout_file">
          <item>
            <widget class="QPushButton" name="save">
              <property name="text"><string>Save</string></property>
            </widget>
          </item>
          <item>
            <widget class="QPushButton" name="load">
              <property name="text"><string>Load</string></property>
            </widget>
          </item>
        </layout>
      </item>

      <!-- Row 14: Clear -->
      <item row="14" column="1" colspan="3">
        <widget class="QPushButton" name="clear">
          <property name="text"><string>Clear</string></property>
        </widget>
      </item>

      <!-- Row 15: Apply all -->
      <item row="15" column="1" colspan="3">
        <widget class="QCheckBox" name="apply_all">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Apply to all topics</string></property>
          <property name="checked"><bool>true</bool></property>
        </widget>
      </item>

      <!-- Row 16: Status -->
      <item row="16" column="0">
        <widget class="QLabel" name="label_status">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="text"><string>Status:</string></property>
        </widget>
      </item>
      <item row="16" column="1" colspan="3">
        <widget class="QLabel" name="status">
          <property name="font"><font><family>Sans Serif</family><pointsize>8</pointsize></font></property>
          <property name="styleSheet"><string notr="true" /></property>
          <property name="text"><string>Click to add waypoints</string></property>
          <property name="wordWrap"><bool>true</bool></property>
          <property name="alignment"><set>Qt::AlignLeading|Qt::AlignLeft|Qt::AlignVCenter</set></property>
        </widget>
      </item>

    </layout>
  </widget>

  <resources />
  <connections />
</ui>
